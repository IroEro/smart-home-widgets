{
  "appId": "app.lovable.ewpetest",
  "appName": "EWPE Smart",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "server": {
    "url": "https://ewpetest.lovableproject.com?forceHideBadge=true",
    "cleartext": true
  },
  "android": {
    "allowMixedContent": true,
    "backgroundColor": "#0d1117"
    "namespace" : "app.lovable.ewpetest" 
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1000,
      "backgroundColor": "#0d1117",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP"
    }
  }
}
